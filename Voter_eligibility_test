#include <stdio.h>

int main() {
    int age;

    // Ask user to enter age
    printf("Enter your age: ");
    scanf("%d", &age);

    // Check eligibility
    if (age >= 18) {
        printf("You are eligible to vote.\n");
    } else if (age > 0 && age < 18) {
        printf("You are not eligible to vote.\n");
    } else {
        printf("Invalid age entered.\n");
    }

    return 0;
}